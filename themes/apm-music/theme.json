{
  "name": "APM Music",
  "id": "apm-music",
  "version": "1.0.0",
  "author": "APM Music brand palette",
  "license": "Proprietary",
  "defaultMode": "dark",
  "branding": {
    "windowTitle": "APM Code Assistant",
    "welcomeMessage": "What are you working on?"
  },
  "typography": {
    "fontFamily": "Poppins, Inter, -apple-system, BlinkMacSystemFont, sans-serif",
    "fontMono": "JetBrains Mono, SF Mono, Menlo, monospace",
    "fontSize": "14px",
    "lineHeight": "1.6"
  },
  "dark": {
    "bgPrimary": "#0a0a0a",
    "bgSecondary": "#000002",
    "bgTertiary": "#1a1a1a",
    "accent": "#CC1F3C",
    "accentHover": "#e0334f",
    "textPrimary": "#f0f0f0",
    "textSecondary": "#d9d9d9",
    "textMuted": "#707070",
    "success": "#34a853",
    "error": "#CC1F3C",
    "warning": "#e5a830",
    "border": "#2a2a2a",
    "borderActive": "#404040",
    "codeBlockBg": "#000002",
    "selection": "hsla(349, 74%, 46%, 0.25)",
    "scrollbarThumb": "#333333",
    "scrollbarTrack": "#0a0a0a"
  },
  "light": {
    "bgPrimary": "#ffffff",
    "bgSecondary": "#f5f5f5",
    "bgTertiary": "#e7e7e7",
    "accent": "#CC1F3C",
    "accentHover": "#a8182f",
    "textPrimary": "#000002",
    "textSecondary": "#555555",
    "textMuted": "#999999",
    "success": "#2d8a45",
    "error": "#CC1F3C",
    "warning": "#c99020",
    "border": "#d9d9d9",
    "borderActive": "#b0b0b0",
    "codeBlockBg": "#f5f5f5",
    "selection": "hsla(349, 74%, 46%, 0.15)",
    "scrollbarThumb": "#c5c5c5",
    "scrollbarTrack": "#ffffff"
  }
}
